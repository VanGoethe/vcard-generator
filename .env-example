# Env
NODE_ENV=dev
NEXT_PUBLIC_DEVELOPMENT_URL="http://localhost:3000"
NEXT_PUBLIC_PRODUCTION_URL="https://ecard.immap.org"

# Microsoft Entra (Azure AD) — MSAL + Microsoft Graph User.Read
# In App registration → Authentication, add redirect URIs under "Single-page application"
# (not "Web"), or token redemption fails with AADSTS9002326. See docs/azure-spa-redirect.md
NEXT_PUBLIC_MSAL_CLIENT_ID="your id"
NEXT_PUBLIC_MSAL_TENANT_ID="your id"

# Prisma — local PostgreSQL (adjust user, password, port, and database name to match your install)
# If you add `.env.local`, it overrides `.env` in Next.js — keep DATABASE_URL in sync there too.
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE_NAME"